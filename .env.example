# ── Datadog Core ──────────────────────────────────────────────────────────────
DD_API_KEY=your_dd_api_key_here
DD_APP_KEY=your_dd_app_key_here
DD_SITE=datadoghq.com

# Unique per user — used as the env tag in APM, Logs, and Dashboards.
DD_ENV=local-yourname

# ── Observability Pipelines Worker ────────────────────────────────────────────
# Leave empty to skip OPW. Guide: https://docs.datadoghq.com/cloudprem/ingest/observability_pipelines/
DD_OP_PIPELINE_ID=

# OPW destination URL. Defaults to http://cloudprem:7280.
DD_OP_DESTINATION_CLOUDPREM_URL=
